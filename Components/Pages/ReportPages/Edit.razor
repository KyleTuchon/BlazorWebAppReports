@page "/reports/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppReports.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<BlazorWebAppReports.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

<PageTitle>Edit Report</PageTitle>

<h1>Edit</h1>

<h2>Report</h2>
<hr />

@if (Report is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="Report" OnValidSubmit="UpdateReport" FormName="edit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Report.Title" class="form-control" />
                    <ValidationMessage For="() => Report.Title" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="duedate" class="form-label">Due Date:</label>
                    <InputDate id="duedate" @bind-Value="Report.DueDate" class="form-control" />
                    <ValidationMessage For="() => Report.DueDate" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="type" class="form-label">Type:</label>
                    <InputSelect id="type" class="form-control" @bind-Value="Report.Type">
                        <option value="">-- Select Type --</option>
                        <option value="Bug">Bug</option>
                        <option value="Feature">Feature</option>
                        <option value="Nice to Have">Nice to Have</option>
                        <option value="Other">Other</option>
                    </InputSelect>
                    <ValidationMessage For="() => Report.Type" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="priority" class="form-label">Priority:</label>
                    <InputSelect id="priority" class="form-control" @bind-Value="Report.Priority">
                        <option value="1">1 - Low</option>
                        <option value="2">2 - Medium</option>
                        <option value="3">3 - High</option>
                        <option value="4">4 - Critical</option>
                    </InputSelect>
                    <ValidationMessage For="() => Report.Priority" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="assignedTo" class="form-label">Assigned To:</label>
                    <InputSelect id="assignedTo" class="form-control" @bind-Value="Report.AssignedTo">
                        <option value="">-- Select Team Member --</option>
                        <option value="Christina Chamberlain">Christina Chamberlain</option>
                        <option value="Kyle Tuchon">Kyle Tuchon</option>
                        <option value="Braden Cantu">Braden Cantu</option>
                        <option value="Danielle McCartney">Danielle McCartney</option>
                        <option value="Benjamin Sherill">Benjamin Sherill</option>
                    </InputSelect>
                    <ValidationMessage For="() => Report.AssignedTo" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="status" class="form-label">Status:</label>
                    <InputSelect id="status" class="form-control" @bind-Value="Report.Status">
                        <option value="">-- Select Status --</option>
                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Pending">Pending</option>
                        <option value="Resolved">Resolved</option>
                        <option value="Closed">Closed</option>
                    </InputSelect>
                    <ValidationMessage For="() => Report.Status" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <InputTextArea id="description" @bind-Value="Report.Description" class="form-control" />
                    <ValidationMessage For="() => Report.Description" class="text-danger" />
                </div>

                @if (!string.IsNullOrWhiteSpace(Report.ImagePath))
                {
                    <div class="mb-3">
                        <label class="form-label">Current Proof Image:</label>
                        <br />
                        <img src="@Report.ImagePath"
                             alt="Current proof image"
                             style="max-width: 250px; max-height: 250px; border: 1px solid #ccc; border-radius: 8px;" />
                        <br />
                        <a href="@Report.ImagePath" target="_blank">View Full Image</a>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Upload New Proof Image:</label>
                    <InputFile OnChange="HandleFileUpload" class="form-control" />
                    <small class="text-muted">
                        Leave blank to keep the current image.
                    </small>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/reports" class="btn btn-secondary ms-2">Cancel</a>
            </EditForm>
        </div>
    </div>
}

<div class="mt-3">
    <a href="/reports">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    public int Id { get; set; }

    private Report? Report { get; set; }

    private IBrowserFile? uploadedFile;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        Report = await context.Report.FirstOrDefaultAsync(r => r.Id == Id);

        if (Report is null)
        {
            NavigationManager.NavigateTo("/reports");
        }
    }

    private void HandleFileUpload(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
    }

    private async Task UpdateReport()
    {
        if (Report is null)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();

        if (uploadedFile is not null)
        {
            var uploadsFolder = Path.Combine(Environment.WebRootPath, "uploads");

            if (!Directory.Exists(uploadsFolder))
            {
                Directory.CreateDirectory(uploadsFolder);
            }

            var fileName = $"{Guid.NewGuid()}_{uploadedFile.Name}";
            var filePath = Path.Combine(uploadsFolder, fileName);

            await using var stream = uploadedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            await using var fileStream = new FileStream(filePath, FileMode.Create);

            await stream.CopyToAsync(fileStream);

            Report.ImagePath = $"/uploads/{fileName}";
        }

        context.Attach(Report).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/reports");
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!ReportExists(Report.Id))
            {
                NavigationManager.NavigateTo("/reports");
            }
            else
            {
                throw;
            }
        }
    }

    private bool ReportExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Report.Any(r => r.Id == id);
    }
}